.replit
.replit-artifact
replit.nix
.local
.upm
.cache

# Env files — never bake secrets into the image
.env
.env.*
!.env.example

# Mockup sandbox — not needed in production images
artifacts/mockup-sandbox

# Logs
*.log

# OS
.DS_Store
Thumbs.db
