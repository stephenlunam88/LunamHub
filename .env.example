# LunamHub — NAS deployment environment variables
# Copy this file to .env on the NAS and fill in real values.
# The .env file is NOT committed to git.

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_DB=lunamhub
POSTGRES_USER=lunam
POSTGRES_PASSWORD=changeme

# DATABASE_URL is assembled by docker-compose from the Postgres vars above;
# you do not need to set it manually.

# ── Application ────────────────────────────────────────────────────────────────

# A long random string used to sign session cookies.
# Generate one with: openssl rand -hex 64
SESSION_SECRET=replace-with-a-long-random-string

# ── Optional ───────────────────────────────────────────────────────────────────

# Port exposed on the NAS host (default: 3000)
WEB_PORT=3000

# Log verbosity: trace | debug | info | warn | error (default: info)
LOG_LEVEL=info
