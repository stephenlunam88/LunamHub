# LunamHub — NAS deployment environment variables
# Copy this file to .env on the NAS and fill in real values.
# The .env file is NOT committed to git.

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_DB=lunamhub
POSTGRES_USER=lunam
POSTGRES_PASSWORD=changeme

# DATABASE_URL is assembled by docker-compose from the Postgres vars above.
# If the password contains URL-reserved characters (for example /, @, :, or #),
# set DATABASE_URL explicitly and percent-encode its password component.
# DATABASE_URL=postgresql://lunam:change%2Fme@db:5432/lunamhub

# ── Application ────────────────────────────────────────────────────────────────

# A long random string used to sign session cookies.
# Generate one with: openssl rand -hex 64
SESSION_SECRET=replace-with-a-long-random-string

# App-level password shown on the login screen.
# If left empty, the login screen is skipped (useful for purely local setups).
# Change this to something strong before exposing to the internet.
APP_PASSWORD=

# ── Google Calendar OAuth ───────────────────────────────────────────────────────
# Required for Google Calendar sync. Create credentials in Google Cloud Console:
#   https://console.cloud.google.com/apis/credentials
# 1. Create an "OAuth 2.0 Client ID" of type "Web application"
# 2. Add your NAS address as an Authorised redirect URI:
#      http://<nas-ip>:<WEB_PORT>/api/auth/google/callback
# 3. Enable the "Google Calendar API" in your project
#
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ── Optional ───────────────────────────────────────────────────────────────────

# Port exposed on the NAS host (default: 3000)
WEB_PORT=3000

# Log verbosity: trace | debug | info | warn | error (default: info)
LOG_LEVEL=info

# ── Screensaver photo storage ───────────────────────────────────────────────────
# On NAS/Docker, photos uploaded via Admin > Screensaver are stored on a named
# Docker volume (photos_data) mounted at /data/photos inside the api container.
# This is automatic — no extra config needed. Photos survive container restarts.
#
# To override the storage path inside the container (advanced):
# LOCAL_PHOTO_DIR=/data/photos
#
# NOTE: On Replit, photos use Replit Object Storage instead (PRIVATE_OBJECT_DIR
# env var must be set). When PRIVATE_OBJECT_DIR is absent (NAS), local disk is
# used automatically.
