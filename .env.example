# LunamHub — NAS deployment environment variables
# Copy this file to .env on the NAS and fill in real values.
# The .env file is NOT committed to git.

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_DB=lunamhub
POSTGRES_USER=lunam
POSTGRES_PASSWORD=changeme

# DATABASE_URL is assembled by docker-compose from the Postgres vars above;
# you do not need to set it manually.

# ── Application ────────────────────────────────────────────────────────────────

# A long random string used to sign session cookies.
# Generate one with: openssl rand -hex 64
SESSION_SECRET=replace-with-a-long-random-string

# ── Optional ───────────────────────────────────────────────────────────────────

# Port exposed on the NAS host (default: 3000)
WEB_PORT=3000

# Log verbosity: trace | debug | info | warn | error (default: info)
LOG_LEVEL=info

# ── Screensaver photo storage ───────────────────────────────────────────────────
# On NAS/Docker, photos uploaded via Admin > Screensaver are stored on a named
# Docker volume (photos_data) mounted at /data/photos inside the api container.
# This is automatic — no extra config needed. Photos survive container restarts.
#
# To override the storage path inside the container (advanced):
# LOCAL_PHOTO_DIR=/data/photos
#
# NOTE: On Replit, photos use Replit Object Storage instead (PRIVATE_OBJECT_DIR
# env var must be set). When PRIVATE_OBJECT_DIR is absent (NAS), local disk is
# used automatically.
